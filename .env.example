# ─── OpenAI (primary AI) ─────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# ─── Google Gemini (fallback AI) ─────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── ElevenLabs ──────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# Default voice — replace with a cloned family voice for best effect
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# ─── Cloudinary ──────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ─── Backboard.io ─────────────────────────────────────────────────────────────
BACKBOARD_API_KEY=your_backboard_api_key

# ─── Capture Mode ─────────────────────────────────────────────────────────────
# "glasses" = receive frames from Meta glasses iOS app via WebSocket
# "screen"  = grab a screen region using mss (legacy)
CAPTURE_MODE=glasses

# Meta glasses WebSocket (only used when CAPTURE_MODE=glasses)
GLASSES_WS_HOST=0.0.0.0
GLASSES_WS_PORT=8765

# Screen capture region (only used when CAPTURE_MODE=screen)
CAPTURE_LEFT=0
CAPTURE_TOP=0
CAPTURE_WIDTH=1280
CAPTURE_HEIGHT=720

# ─── Face Recognition (InsightFace) ──────────────────────────────────────────
# Path is relative to the backend/ directory
FACE_DB_PATH=data/face_db
# "buffalo_sc" = fast (~30ms), "buffalo_l" = more accurate (~60ms)
FACE_MODEL=buffalo_sc
# Detection input size — 640 is reliable, 320 is faster for close-up faces
FACE_DET_SIZE=640
# Cosine similarity threshold — higher = stricter (0.3 lenient, 0.5 strict)
FACE_SIMILARITY_THRESHOLD=0.4
# Seconds to wait before re-identifying the same person
FACE_COOLDOWN_SECONDS=30

# ─── App ─────────────────────────────────────────────────────────────────────
DEBUG=true
PORT=8000
# Patient name — used in grounding messages
PATIENT_NAME=Dad
