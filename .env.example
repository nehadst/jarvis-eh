# ─── Google Gemini ───────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── ElevenLabs ──────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# Default voice — replace with a cloned family voice for best effect
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# ─── Cloudinary ──────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ─── Backboard.io ─────────────────────────────────────────────────────────────
BACKBOARD_API_KEY=your_backboard_api_key

# ─── Screen Capture Region ────────────────────────────────────────────────────
# Pixel coordinates of the WhatsApp call window on your screen.
# Run: python backend/capture/calibrate.py  to find these values.
CAPTURE_LEFT=0
CAPTURE_TOP=0
CAPTURE_WIDTH=1280
CAPTURE_HEIGHT=720

# ─── Face Recognition ────────────────────────────────────────────────────────
# Path is relative to the backend/ directory
FACE_DB_PATH=data/face_db
FACE_MODEL=ArcFace
FACE_DETECTOR=retinaface
# Lower = stricter match. 0.4 is a good default for ArcFace + cosine.
FACE_DISTANCE_THRESHOLD=0.4
# Seconds to wait before re-identifying the same person
FACE_COOLDOWN_SECONDS=30

# ─── App ─────────────────────────────────────────────────────────────────────
DEBUG=true
PORT=8000
# Patient name — used in grounding messages
PATIENT_NAME=Dad
